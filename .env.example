APP_NAME="Reservasi Bulutangkis"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_TIMEZONE=Asia/Makassar
APP_URL=http://localhost:8000

APP_LOCALE=id
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=id_ID

APP_MAINTENANCE_DRIVER=file
APP_MAINTENANCE_STORE=database

# ─── Database (Supabase PostgreSQL) ──────────────────────────────────────────
#
# Cara mendapatkan connection string dari Supabase:
# 1. Masuk ke https://supabase.com → pilih project
# 2. Klik Settings → Database
# 3. Copy connection string dari bagian "URI"
# 4. Ganti [YOUR-PASSWORD] dengan password project Supabase kamu
#
# Laravel Eloquent menggunakan DB_* variabel di bawah ini:
DB_CONNECTION=pgsql
DB_HOST=aws-0-[REGION].pooler.supabase.com
DB_PORT=5432
DB_DATABASE=postgres
DB_USERNAME=postgres.[PROJECT-REF]
DB_PASSWORD=your-database-password-here

# ─── Prisma + Supabase (PostgreSQL) ─────────────────────────────────────────
# DATABASE_URL digunakan oleh Prisma Client (runtime, via pgbouncer port 6543)
DATABASE_URL="postgresql://postgres.[PROJECT-REF]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres?pgbouncer=true"

# DIRECT_URL digunakan oleh Prisma Migrate/Push (koneksi langsung, port 5432)
DIRECT_URL="postgresql://postgres.[PROJECT-REF]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:5432/postgres"

# ─── Session ─────────────────────────────────────────────────────────────────
SESSION_DRIVER=file
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

# ─── Cache & Queue ───────────────────────────────────────────────────────────
BROADCAST_CONNECTION=log
CACHE_STORE=file
QUEUE_CONNECTION=sync

# ─── Redis (opsional) ────────────────────────────────────────────────────────
REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# ─── Mail ────────────────────────────────────────────────────────────────────
MAIL_MAILER=log
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="noreply@reservasi-badminton.com"
MAIL_FROM_NAME="${APP_NAME}"

# ─── Filesystem ──────────────────────────────────────────────────────────────
FILESYSTEM_DISK=local
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

# ─── Logging ─────────────────────────────────────────────────────────────────
LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug
